INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (3, 13, 'Tôm ', '345000', 1, 'Hải sản tươi sống gồm tôm, mực, nghêu, sò được chế biến đậm đà, giữ vị ngọt tự nhiên, thơm lừng, hấp dẫn, phù hợp mọi bữa ăn gia đình.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (4, 2, 'Gà Chiên Kiểu Pháp', '120000', 1, 'Gà chiên giòn rụm, vàng ươm hấp dẫn, lớp vỏ ngoài giòn tan, bên trong thịt mềm ngọt, thơm lừng gia vị, ăn kèm nước chấm đậm đà rất cuốn vị.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (5, 12, 'Bánh ngọt', '40000', 1, 'Bánh tráng miệng ngọt ngào, mềm mịn, hương vị thanh nhẹ, thường kết hợp trái cây hoặc kem, tạo cảm giác tươi mát, dễ ăn sau bữa chính.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (6, 15, 'Hambuger ý', '55000', 1, 'Thức ăn nhanh là các món chế biến sẵn, phục vụ nhanh chóng như hamburger, gà rán, khoai tây chiên, tiện lợi, ngon miệng nhưng thường nhiều năng lượng và chất béo.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (7, 14, 'Trà đào', '35000', 1, 'Trà đào thơm mát, vị trà thanh nhẹ hòa cùng đào ngọt dịu, có thể thêm miếng đào giòn và đá lạnh, tạo cảm giác sảng khoái, rất được yêu thích ngày hè.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (8, 6, 'Nước lọc', '10000', 1, 'Nước lọc tinh khiết hãng thân thuộc với người dùng việt nam');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (9, 14, 'Nước ép dưa lê', '25000', 1, 'Nước ép trái cây tươi mát, giàu vitamin, giữ nguyên hương vị tự nhiên của trái cây như cam, táo, dứa, giúp giải khát, thanh lọc cơ thể và bổ sung năng lượng.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (10, 12, 'Bánh tacos', '78000', 1, 'Bánh tacos giòn thơm, vỏ bánh gấp hình bán nguyệt, bên trong là thịt, rau, phô mai và sốt đậm đà, mang hương vị Mexico đặc trưng, hấp dẫn và dễ ăn.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (11, 9, 'Thịt trâu nướng lá ngón', '420000', 1, 'Thịt nướng thơm lừng, được tẩm ướp đậm đà rồi nướng trên than hoặc lò, bên ngoài xém nhẹ, bên trong mềm ngọt, ăn kèm rau sống và nước chấm rất hấp dẫn.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (12, 7, 'Shushi nhật bản', '560000', 1, 'Sushi là món ăn Nhật Bản tinh tế, gồm cơm trộn giấm kết hợp hải sản tươi sống, trứng hoặc rau củ, cuộn hoặc nắm gọn gàng, vị thanh nhẹ, đẹp mắt và giàu dinh dưỡng.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (13, 9, 'Gà nướng lá móc mật', '320000', 1, 'Gà nướng thơm lừng, được tẩm ướp đậm đà rồi nướng trên than hoặc lò, bên ngoài xém nhẹ, bên trong mềm ngọt, ăn kèm rau sống và nước chấm rất hấp dẫn.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (14, 8, 'Lẩu tứ xuyên trung quốc', '500000', 1, 'Lẩu Tứ Xuyên Trung Quốc nổi tiếng vị cay nồng, tê đặc trưng từ tiêu Tứ Xuyên, nước dùng đậm đà, kết hợp nhiều loại thịt, rau và nấm, mang hương vị mạnh mẽ, hấp dẫn và rất kích thích vị giác.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (15, 1, 'Nghêu hấp dừa', '80000', 1, 'Nghêu hấp dừa thơm béo, nghêu tươi ngọt tự nhiên hòa quyện cùng nước dừa thanh mát, vị ngọt dịu nhẹ, đậm đà, tạo cảm giác dễ ăn và rất hấp dẫn.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (2, 2, 'gà hấp', '123455', 1, 'Gà hấp thơm mềm, thịt gà giữ được độ ngọt tự nhiên, thấm nhẹ gia vị, da vàng óng, không dầu mỡ, thường ăn kèm muối tiêu chanh hoặc nước mắm gừng rất đậm đà.');
INSERT INTO "mon_ans" ("ma_mon_an", "ma_loai_mon_an", "ten_mon_an", "gia_tien", "trang_thai", "mo_ta") VALUES (1, 2, 'Gà Chiên ', '123443', 1, 'Gà chiên giòn rụm, lớp vỏ vàng óng thơm lừng, bên trong thịt mềm ngọt, đậm vị gia vị, ăn kèm sốt hoặc tương ớt rất hấp dẫn và dễ gây “nghiện”.');


